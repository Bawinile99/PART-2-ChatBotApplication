<Window x:Class="POEChatBotApplication.SplashScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="iie Cyber-Bot 🤖 智能助理"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Height="600"
        Width="600"
        Loaded="Window_Loaded">

    <Grid>
        <!-- Background Gradient -->
        <Ellipse Width="800" Height="800" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Ellipse.Fill>
                <RadialGradientBrush GradientOrigin="0.5,0.5">
                    <GradientStop Color="#000000" Offset="0.0"/>
                    <GradientStop Color="#880000" Offset="0.5"/>
                    <GradientStop Color="#FFFFFF" Offset="1.0"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <!-- Circular Progress -->
        <Viewbox Width="200" Height="200" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Grid>
                <!-- Background Circle -->
                <Ellipse Stroke="#FFCCCC" StrokeThickness="10"/>

                <!-- Foreground Arc using Path -->
                <Path x:Name="ProgressArc"
                      Stroke="#FF0000"
                      StrokeThickness="10"
                      Fill="Transparent"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round">
                    <Path.Data>
                        <PathGeometry>
                            <PathFigure x:Name="ProgressFigure"
                                        StartPoint="100,0"
                                        IsClosed="False">
                                <ArcSegment x:Name="ProgressArcSegment"
                                            Point="100,0"
                                            Size="90,90"
                                            SweepDirection="Clockwise"
                                            IsLargeArc="False"/>
                            </PathFigure>
                        </PathGeometry>
                    </Path.Data>
                </Path>

                <!-- Text inside circle -->
                <TextBlock Text="IIE Cyber Bot...🧠" 
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="White"/>
            </Grid>
        </Viewbox>

        <!-- Welcome Message -->
        <StackPanel VerticalAlignment="Bottom" Margin="0,0,0,40" HorizontalAlignment="Center">
            <TextBlock Text="🎉 欢迎使用 iie Cyber-Bot!"
                       FontFamily="Orbitron"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#FF0000"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="⚡ Connecting to neural grid..."
                       FontSize="18"
                       FontStyle="Italic"
                       Foreground="Black"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
